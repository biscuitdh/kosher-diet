LLM_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Grok / xAI
GROK_API_KEY=
GROK_MODEL=grok-2-latest
GROK_BASE_URL=https://api.x.ai/v1

# Optional runtime tuning
AI_REQUEST_TIMEOUT_MS=30000
AI_MAX_REQUEST_BODY_BYTES=65536
AI_RATE_LIMIT_MAX_BUCKETS=2048

# Required in production when LLM_PROVIDER is not mock.
# Send as Authorization: Bearer <key> or x-ai-generation-key.
AI_GENERATION_API_KEY=

# Only enable when a trusted proxy strips and rewrites these headers.
AI_RATE_LIMIT_TRUST_PROXY_HEADERS=false
