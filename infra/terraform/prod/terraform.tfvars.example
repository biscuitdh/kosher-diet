project_id         = "koshertable-prod"
billing_account_id = "000000-000000-000000"

allowed_emails = [
  "you@example.com",
  "wife@example.com"
]

google_oauth_client_id     = "000000000000-example.apps.googleusercontent.com"
google_oauth_client_secret = "do-not-commit-real-secret"

cloudflare_zone_id              = "00000000000000000000000000000000"
cloudflare_account_id           = "00000000000000000000000000000000"
cloudflare_api_token            = "do-not-commit-real-token"
budget_amount_usd               = 5
github_repository               = "biscuitdh/webapps"
firestore_location              = "nam5"
domain                          = "kosher.netsbyvets.org"
hosting_site_id                 = "koshertable-prod"
cloudflare_zero_trust_team_name = "netsbyvets"

# Leave empty for the first apply. After Terraform outputs
# firebase_custom_domain_dns_updates, translate those records here and apply
# again so Cloudflare DNS is managed by Terraform. Keep proxied=false while
# Firebase provisions SSL; switch proxied=true after Cloudflare Access exists.
firebase_dns_records = []

